{
  "name": "lunasuite-launcher",
  "private": true,
  "version": "0.0.2",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "build": "tsc -b && vite build",
    "build:desktop": "node scripts/clean-installers.mjs && npm run build && electron-builder --win nsis --publish never",
    "preview": "vite preview"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "electron": "^36.9.5",
    "electron-builder": "^26.0.12",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.2",
    "vite": "^8.0.16"
  },
  "build": {
    "appId": "de.lunasuite.launcher",
    "productName": "LunaSuite Launcher",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/icon.ico",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LunaSuite Launcher"
    }
  }
}
